{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://anci.gob.cl/api/:path*"
    },
    {
      "source": "/global-threats/:path*",
      "destination": "https://www.cisa.gov/sites/default/files/feeds/:path*"
    },
    {
      "source": "/raw-rss/:path*",
      "destination": "https://feeds.feedburner.com/:path*"
    },
    {
      "source": "/gtx/:path*",
      "destination": "https://translate.googleapis.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
